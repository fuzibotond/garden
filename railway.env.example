# ============================================================
# Railway environment variables — copy these into each service
# in the Railway dashboard under Settings > Variables.
#
# Use Railway's reference syntax ${{Service.VAR}} to link
# values between services instead of copy-pasting hostnames.
# ============================================================

# ── garden-api ──────────────────────────────────────────────

ASPNETCORE_ENVIRONMENT=Production

# Admin seed account
Admin__Email=admin@yourdomain.com
Admin__Password=<strong-password>

# JWT — generate with: openssl rand -base64 64
Jwt__Key=<64-char-random-string>
Jwt__Issuer=Garden.Api
Jwt__Audience=Garden.App

# SQL Server (Railway internal hostname of the sqlserver service)
# In Railway dashboard use: ${{sqlserver.RAILWAY_PRIVATE_DOMAIN}}
ConnectionStrings__GardenDb=Server=${{sqlserver.RAILWAY_PRIVATE_DOMAIN}},1433;Database=GardenDb;User Id=sa;Password=${{sqlserver.SA_PASSWORD}};TrustServerCertificate=True;

# RabbitMQ (Railway internal hostname of the rabbitmq service)
RabbitMq__HostName=${{rabbitmq.RAILWAY_PRIVATE_DOMAIN}}
RabbitMq__Port=5672
RabbitMq__UserName=${{rabbitmq.RABBITMQ_DEFAULT_USER}}
RabbitMq__Password=${{rabbitmq.RABBITMQ_DEFAULT_PASS}}
RabbitMq__ExchangeName=garden.events

# SMTP — use MailHog for staging, a real provider (Resend, Postmark) for production
Smtp__Host=${{mailhog.RAILWAY_PRIVATE_DOMAIN}}
Smtp__Port=1025
Smtp__FromAddress=noreply@yourdomain.com
Smtp__EnableSsl=false

# Public URLs — set after first deploy when Railway assigns URLs
Frontend__BaseUrl=https://<your-web-service>.up.railway.app
FileStorage__BaseUrl=https://<your-api-service>.up.railway.app/uploads

# ── garden-web ───────────────────────────────────────────────

# nginx reverse-proxy target — Railway internal address of the API
# In Railway dashboard use: http://${{garden-api.RAILWAY_PRIVATE_DOMAIN}}:${{garden-api.PORT}}
BACKEND_URL=http://${{garden-api.RAILWAY_PRIVATE_DOMAIN}}:${{garden-api.PORT}}

# ── sqlserver (custom Docker service) ───────────────────────
# Image: mcr.microsoft.com/mssql/server:2022-latest

ACCEPT_EULA=Y
MSSQL_SA_PASSWORD=<strong-password-min-8-chars-mixed-case-number-symbol>

# ── rabbitmq (Railway template or custom Docker) ─────────────
# Image: rabbitmq:4.0-management-alpine

RABBITMQ_DEFAULT_USER=garden
RABBITMQ_DEFAULT_PASS=<strong-password>

# ── mailhog (staging only — replace with real SMTP in production) ──
# Image: mailhog/mailhog:latest
# No env vars needed for basic use.
# Web UI runs on port 8025 — expose via Railway if you want to inspect emails.
