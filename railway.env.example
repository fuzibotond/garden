# ============================================================
# RAILWAY DEPLOYMENT � COMPLETE ENVIRONMENT VARIABLE GUIDE
# GitHub Actions secrets for CI/CD are listed in: github-secrets.example.env
#
# HOW TO USE:
#   1. Create a Railway project at https://railway.app
#   2. Add services in the ORDER listed below
#   3. Set the variables for each service from this file
#   4. Railway resolves ${{service.VAR}} references automatically
#
# ORDER MATTERS: create sqlserver, rabbitmq, mailhog BEFORE the API
# so Railway can resolve the cross-service ${{...}} references.
# ============================================================


# ================================================================
# 1. sqlserver
# + New -> Docker Image -> mcr.microsoft.com/mssql/server:2022-latest
# ================================================================

ACCEPT_EULA=Y
MSSQL_SA_PASSWORD=Str0ng!Pass2026       # min 8 chars, uppercase, number, symbol


# ================================================================
# 2. rabbitmq
# + New -> Docker Image -> rabbitmq:3-management-alpine
# ================================================================

RABBITMQ_DEFAULT_USER=garden
RABBITMQ_DEFAULT_PASS=RabbitStr0ng2026


# ================================================================
# 3. mailhog  (dev/staging email catcher � no vars needed)
# + New -> Docker Image -> mailhog/mailhog
# Expose port 8025 if you want to browse captured emails.
# ================================================================


# ================================================================
# 4. garden-api
# + New -> GitHub Repo -> your repo -> Root Directory: leave blank
# ================================================================

ASPNETCORE_ENVIRONMENT=Production

# JWT � generate a key: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
Jwt__Key=REPLACE_WITH_64_BYTE_BASE64_STRING
Jwt__Issuer=Garden.Api
Jwt__Audience=Garden.App

# Admin seed account created on first startup
Admin__Email=admin@yourdomain.com
Admin__Password=AdminStr0ng2026

# Database � Railway resolves ${{sqlserver.*}} to the internal hostname
ConnectionStrings__GardenDb=Server=${{sqlserver.RAILWAY_PRIVATE_DOMAIN}},1433;Database=GardenDb;User Id=sa;Password=${{sqlserver.MSSQL_SA_PASSWORD}};TrustServerCertificate=True;

# RabbitMQ � Railway resolves ${{rabbitmq.*}} to the internal hostname
RabbitMq__HostName=${{rabbitmq.RAILWAY_PRIVATE_DOMAIN}}
RabbitMq__Port=5672
RabbitMq__UserName=${{rabbitmq.RABBITMQ_DEFAULT_USER}}
RabbitMq__Password=${{rabbitmq.RABBITMQ_DEFAULT_PASS}}
RabbitMq__ExchangeName=garden.events

# Email � Railway resolves ${{mailhog.*}} to the internal hostname
Smtp__Host=${{mailhog.RAILWAY_PRIVATE_DOMAIN}}
Smtp__Port=1025
Smtp__FromAddress=noreply@garden.local
Smtp__EnableSsl=false

# Public URLs � fill in AFTER first deploy (copy the .up.railway.app domain from each service)
Frontend__BaseUrl=https://REPLACE_WITH_WEB_SERVICE_DOMAIN.up.railway.app
FileStorage__BaseUrl=https://REPLACE_WITH_API_SERVICE_DOMAIN.up.railway.app/uploads


# ================================================================
# 5. garden-web
# + New -> GitHub Repo -> same repo -> Root Directory: apps/web
# ================================================================

# nginx proxies /api/* to this internal URL � Railway resolves the private domain
# Use the API container port directly; do not use ${{garden-api.PORT}} (it may be empty).
BACKEND_URL=http://${{garden-api.RAILWAY_PRIVATE_DOMAIN}}:8080


# ================================================================
# MOBILE APP � Expo EAS (not hosted on Railway, calls the Railway API)
# ================================================================
#
# Before building: set EXPO_PUBLIC_API_URL to your Railway API domain:
#   echo "EXPO_PUBLIC_API_URL=https://REPLACE_WITH_API_DOMAIN.up.railway.app" > apps/mobile-app/.env
#
# Build a shareable Android APK (no Play Store account needed):
#   cd apps/mobile-app
#   npx eas login
#   npx eas build --platform android --profile preview
#
# EAS uploads the build to expo.dev and gives you a download link.
# Share that link to install the app on any Android device.
# ================================================================
