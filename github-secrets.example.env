# GitHub Actions repository secrets example
# Add these in: GitHub -> Repository -> Settings -> Secrets and variables -> Actions -> New repository secret

# ============================================================
# Required by .github/workflows/deploy-railway-main.yml
# ============================================================

# Railway personal/project token with deploy permissions
RAILWAY_TOKEN=rwv2_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Railway project where your services live (Project Settings)
RAILWAY_PROJECT_ID=11111111-2222-3333-4444-555555555555

# Railway environment ID (usually production)
RAILWAY_ENVIRONMENT_ID=66666666-7777-8888-9999-aaaaaaaaaaaa

# Service IDs inside the same Railway project
RAILWAY_API_SERVICE_ID=bbbbbbbb-cccc-dddd-eeee-ffffffffffff
RAILWAY_WEB_SERVICE_ID=12121212-3434-5656-7878-909090909090

# ============================================================
# Required by .github/workflows/mobile-eas-main.yml
# ============================================================

# Expo/EAS access token from https://expo.dev/accounts/<owner>/settings/access-tokens
EXPO_TOKEN=expo_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public API URL your mobile app should call in cloud builds
MOBILE_API_BASE_URL=https://your-api-service.up.railway.app

# Optional but recommended (if you later add iOS submit workflow)
# APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
# APP_STORE_CONNECT_API_KEY_ID=ABC123DEF4
# APP_STORE_CONNECT_ISSUER_ID=11111111-2222-3333-4444-555555555555
# APP_STORE_CONNECT_API_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
