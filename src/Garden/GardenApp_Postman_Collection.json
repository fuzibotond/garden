        {
          "name": "Get Job Tasks",
          "request": {
            "description": "Returns paged tasks for a job. Each task now includes `totalMaterialCost` calculated from assigned materials (sum of usedQuantity * pricePerAmount).",
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/gardener/jobs/{{job_id}}/tasks?page=1&pageSize=20",
              "host": ["{{base_url}}"],
              "path": ["api", "gardener", "jobs", "{{job_id}}", "tasks"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "Create Task in Job",
          "request": {
            "description": "Creates a task directly under the given job. `materials` is optional. If provided, each item must contain `materialId` and a positive `usedQuantity`. Response includes `materials` and `totalMaterialCost`.",
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"taskTypeId\": \"{{task_type_id}}\",\n  \"name\": \"Trim hedges\",\n  \"description\": \"Trim front and side hedges\",\n  \"estimatedTimeMinutes\": 120,\n  \"materials\": [\n    {\n      \"materialId\": \"{{material_id}}\",\n      \"usedQuantity\": 1.5\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/gardener/jobs/{{job_id}}/tasks",
              "host": ["{{base_url}}"],
              "path": ["api", "gardener", "jobs", "{{job_id}}", "tasks"]
            }
          }
        }
