    {
      "name": "Gardener - Tasks",
      "description": "Task endpoints now support assigning multiple materials and tracking per-task material costs.",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "description": "Creates a task. `materials` is optional. Use it to assign one or more materials with `usedQuantity`. Response contains `materials` and `totalMaterialCost`.",
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jobId\": \"{{job_id}}\",\n  \"taskTypeId\": \"{{task_type_id}}\",\n  \"name\": \"Mow lawn\",\n  \"description\": \"Cut grass to 2cm\",\n  \"estimatedTimeMinutes\": 60,\n  \"materials\": [\n    {\n      \"materialId\": \"{{material_id}}\",\n      \"usedQuantity\": 2\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/gardener/tasks",
              "host": ["{{base_url}}"],
              "path": ["api", "gardener", "tasks"]
            }
          }
        },
        {
          "name": "Get Task by ID",
          "request": {
            "description": "Returns full task details. Response now includes `materials` (with name, amountType, usedQuantity, pricePerAmount, totalCost) and `totalMaterialCost`.",
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/gardener/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "gardener", "tasks", "{{task_id}}"]
            }
          }
        },
        {
          "name": "Update Task",
          "request": {
            "description": "Updates task fields. If `materials` is included, it replaces existing task-material assignments. Each `usedQuantity` must be greater than 0.",
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Task Name\",\n  \"actualTimeMinutes\": 55,\n  \"finishedAt\": \"2025-03-22T14:30:00Z\",\n  \"materials\": [\n    {\n      \"materialId\": \"{{material_id}}\",\n      \"usedQuantity\": 2.25\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/gardener/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "gardener", "tasks", "{{task_id}}"]
            }
          }
        },
